# NVIDIA NIM (OpenAI-compatible) — https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_MODEL=z-ai/glm-5.2

# Optional Langfuse tracing for Ask Jeethesh.
# Use https://cloud.langfuse.com for EU or https://us.cloud.langfuse.com for US.
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT=development

# NVIDIA Parakeet ASR (speech-to-text for Ask Jeethesh)
# Defaults to the Parakeet CTC 1.1B NVCF transcription endpoint if unset.
# NVIDIA_ASR_URL=https://1598d209-5e27-4d3c-8079-4751568b1081.invocation.api.nvcf.nvidia.com/v1/audio/transcriptions
